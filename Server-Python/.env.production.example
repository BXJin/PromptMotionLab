# Required secrets
ENVIRONMENT=production
OPENAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=koreacentral

# Runtime LLM
OPENAI_RESPONSES_ENDPOINT=https://api.openai.com/v1/responses
OPENAI_ROUTING_ENABLED=1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_NANO_MODEL=gpt-4.1-nano
OPENAI_MAX_OUTPUT_TOKENS=130
OPENAI_NANO_MAX_OUTPUT_TOKENS=110
OPENAI_TEMPERATURE=0.55
OPENAI_NANO_TEMPERATURE=0.75
OPENAI_TIMEOUT_SECONDS=5.5
OPENAI_MAX_CONCURRENCY=3
OPENAI_NANO_MAX_CONCURRENCY=3
RUNTIME_OPENAI_HISTORY_TURNS=20
RUNTIME_PROVIDER_TIMEOUT_SECONDS=6.0
RUNTIME_FALLBACK_TIMEOUT_SECONDS=1.0
RUNTIME_MAX_IN_FLIGHT=16

# Async turn pipeline
RUNTIME_TURN_ASYNC_MAX_JOBS=256
RUNTIME_TURN_ASYNC_JOB_TTL_SECONDS=300
RUNTIME_TURN_ASYNC_PRUNE_INTERVAL_SECONDS=5
RUNTIME_TURN_ASYNC_JOB_TIMEOUT_SECONDS=20
RUNTIME_TURN_ASYNC_MAX_IN_FLIGHT=8
RUNTIME_TURN_SEGMENT_TTS_ENABLED=1
RUNTIME_TURN_MAX_TTS_SEGMENTS=4

# TTS
AZURE_TTS_VOICE=en-US-JennyNeural
AZURE_TTS_KO_VOICE=ko-KR-SunHiNeural
TTS_VISEME_TRIM_TAIL_SECONDS=0.15
TTS_PROVIDER_TIMEOUT_SECONDS=4.0
TTS_FALLBACK_TIMEOUT_SECONDS=1.0
TTS_PROVIDER_MAX_CONCURRENCY=2
TTS_MAX_IN_FLIGHT=16
TTS_AUDIO_TTL_SECONDS=600
TTS_AUDIO_MAX_FILES=512

# Batch STT
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_ENDPOINT=https://api.openai.com/v1/audio/transcriptions
OPENAI_STT_TIMEOUT_SECONDS=4.0
STT_PROVIDER_TIMEOUT_SECONDS=4.0
STT_FALLBACK_TIMEOUT_SECONDS=1.0
STT_PROVIDER_MAX_CONCURRENCY=3
STT_MAX_IN_FLIGHT=16
STT_MAX_AUDIO_BYTES=5242880

# Streaming STT
AZURE_STT_LANGUAGE=ko-KR

# Public API abuse guardrails
# These in-memory limits assume one App Service instance and one uvicorn worker.
# If the server runs multiple workers or instances, replace this with Redis,
# Azure API Management, or an edge gateway limit. Otherwise the effective limit
# is multiplied by the number of worker processes/instances.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RUNTIME_PER_MINUTE=60
RATE_LIMIT_AUDIO_PER_MINUTE=180
RATE_LIMIT_WINDOW_SECONDS=60
WEBSOCKET_RUNTIME_MAX_TOTAL=32
WEBSOCKET_RUNTIME_MAX_PER_CLIENT=2
WEBSOCKET_STT_MAX_TOTAL=32
WEBSOCKET_STT_MAX_PER_CLIENT=2

# Production privacy guardrails
# Keep false for public builds. When false, provider failure samples and model
# parse samples are stored as length/hash markers instead of transcript/reply text.
RUNTIME_LOG_PRIVATE_DATA=false

# Background cleanup
ASYNC_JOB_PRUNE_BACKGROUND_INTERVAL_SECONDS=15
